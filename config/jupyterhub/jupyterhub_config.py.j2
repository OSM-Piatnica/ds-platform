# Extract the spawned image name into `spawner.image` variable.
def apply_user_options(spawner, user_options):
    if "image" in user_options and isinstance(user_options["image"], str):
        spawner.image = c.ResumableDockerSpawner.allowed_images[user_options["image"]]

c.Spawner.apply_user_options = apply_user_options

# Get the project name.
def get_project_name(spawner):
    if spawner.name:
        return spawner.name
    else:
        # If the user is starting their default server, `spawner.name` is
        # empty. (`entrypoint.sh` doesn't allow unnamed projects.)
        return "default-project"

# -----------------------------------------------------------------------------
# Pre-Spawn Hook
# -----------------------------------------------------------------------------
async def pre_spawn_hook(spawner):
    """
    This hook only sets environment variables for the container and defines the
    user's starting directory. All file system operations are delegated to the
    container's entrypoint script for better isolation and stability.
    """

    # -------------------------------------------------------------------------
    # Pass necessary information to the container's entrypoint script.
    # -------------------------------------------------------------------------
  
    # Image name:
    spawner.environment["JUPYTER_IMAGE_SPEC"] = spawner.image

    # Project name:
    project_name = get_project_name(spawner)
    spawner.environment["JUPYTER_PROJECT_NAME"] = project_name

    # User Group membership:
    groups = [group.name for group in spawner.user.groups]

    spawner.log.info(f"DEBUG: User {spawner.user.name} groups: {groups}")

    # -------------------------------------------------------------------------
    # Git Identity Automation
    # -------------------------------------------------------------------------

    # Retrieve user info from Authelia (OIDC).
    auth_state = await spawner.user.get_auth_state()
    user_info = auth_state.get('oauth_user', {})

    # Determine Name and Email.
    # Fallback to JupyterHub username if OIDC name is missing.
    git_name = user_info.get('name', spawner.user.name) 
    # Fallback to placeholder email if OIDC email is missing.
    git_email = user_info.get('email', f"{spawner.user.name}_placeholder@{{ parent_domain }}")

    spawner.log.info(f"Auto-configuring Git identity for {spawner.user.name}: {git_name} <{git_email}>")

    # Inject Environment Variables (Git detects these automatically)
    spawner.environment["GIT_AUTHOR_NAME"] = git_name
    spawner.environment["GIT_AUTHOR_EMAIL"] = git_email
    spawner.environment["GIT_COMMITTER_NAME"] = git_name
    spawner.environment["GIT_COMMITTER_EMAIL"] = git_email

    # -------------------------------------------------------------------------
    # Collaborative Account Configuration
    # -------------------------------------------------------------------------

    # Check if the user spawning server is a collaborative account
    is_collab_server = collab_service_group in groups

    if is_collab_server:
        spawner.log.info(f"Spawning '{project_name}' as a collaborative server")
        # Here, collab-specific configuration can be added.
        # e.g. `spawner.cpu_limit = 4.0`
    
    # -------------------------------------------------------------------------
    # GPU Image Management
    # -------------------------------------------------------------------------
    
    # Dynamically allocate GPUs if the chosen image is a GPU variant
    if "-gpu" in spawner.image:
        spawner.log.info(f"GPU image detected. Allocating GPUs for {project_name}.")
        
        # Create a new dict to prevent mutating a shared Traitlet configuration.
        new_host_config = dict(spawner.extra_host_config)
        new_host_config["device_requests"] = [
            # Note that `count=-1` tells the Docker daemon to pass all available GPUs on the host to the spawned container.
            docker.types.DeviceRequest(count=-1, capabilities=[["gpu"]])
        ]
        spawner.extra_host_config = new_host_config

    # -------------------------------------------------------------------------

    # Set the user's starting directory to their project directory within the
    # container.
    spawner.notebook_dir = f"/home/jovyan/{project_name}"

c.Spawner.pre_spawn_hook = pre_spawn_hook

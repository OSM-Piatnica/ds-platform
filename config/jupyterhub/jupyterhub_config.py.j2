# Deep Learning libraries (e.g., PyTorch) use shared memory for DataLoader workers. 
# The default Docker `shm_size` is 64MB, which might cause 
# "DataLoader worker (pid X) is killed by signal: Bus error".
# Fix: change `shm_size` to higher value.
c.ResumableDockerSpawner.extra_host_config = {
    "shm_size": "2g" # Or higher, based on the host RAM
}


# -----------------------------------------------------------------------------
# Resource Limits & Reservations
# -----------------------------------------------------------------------------

# Limits: 
# Hard cap on usage. 
# The container will be throttled (CPU) or killed (RAM) if exceeded.
c.ResumableDockerSpawner.cpu_limit = 4.0
c.ResumableDockerSpawner.mem_limit = "16G"

# Reservations: 
# The scheduler will only schedule the container if this much is free.
c.ResumableDockerSpawner.cpu_guarantee = 1.0
c.ResumableDockerSpawner.mem_guarantee = "4G"


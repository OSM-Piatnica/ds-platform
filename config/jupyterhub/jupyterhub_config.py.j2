from traitlets import default

# -----------------------------------------------------------------------------
# Custom Class for Additional Container logic
# -----------------------------------------------------------------------------
class ResumableDockerSpawner(DockerSpawner):
    """
    A DockerSpawner that:
    1. Skips the options_form (image choice), if the user's container already
    exists.
    2. Deletes orphaned, stopped containers if a server was deleted from the
    Hub, but the container was left behind.
    3. Syncs SSH keys to Forgejo after start.
    """

    # Override the method that generates the default options form.
    @default("options_form")
    def _options_form_default(self):
        # `spawner.container_id` is populated from the database *before* the
        # form is called. Note that this wouldn't work in `pre_spawn_hook` as
        # restarting container isn't technically a spawn yet (the spawn occurs
        # after the image choice).
        if self.container_id:
            self.log.info(f"Found existing container {self.container_id}, resuming...")
            # Return an empty string to show no form.
            return ""
        
        self.log.info("No existing container found, showing image options form.")
        # Fall back to the default image choice form, by calling the
        # form-building method from the parent class.
        return self._default_options_form()

    # Automatic SSH Key Sync to Forgejo.
    async def sync_ssh_key(self):
        """
        Custom function to sync SSH key to Forgejo after container starts.
        Defined as a method so it has access to `self.user`, `self.log`, etc.
        """

        username = self.user.name
        self.log.info(f"Attempting to sync SSH key for user: {username}")

        try:
            # ---------------------------------------------------------------------
            # STEP 1: READ KEY FROM USER CONTAINER
            # ---------------------------------------------------------------------
            public_key = None
            
            # Retry loop: Wait up to 20 seconds for `entrypoint.sh` to generate the key.
            for i in range(10):
                try:
                    # Use `asyncio.to_thread` to prevent blocking the event loop.
                    # `exec_create` prepares the command.
                    exec_create_resp = await asyncio.to_thread(
                        self.client.exec_create,
                        container=self.container_id,
                        cmd=["cat", "/home/jovyan/.ssh/id_ed25519.pub"],
                        stdout=True
                    )
                    exec_id = exec_create_resp['Id']

                    # `exec_start` runs the command and returns the output.
                    output = await asyncio.to_thread(
                        self.client.exec_start,
                        exec_id=exec_id
                    )

                    # Decode output safely.
                    decoded_key = output.decode('utf-8').strip() if isinstance(output, bytes) else str(output).strip()

                    if "ssh-ed25519" in decoded_key:
                        public_key = decoded_key
                        break

                except Exception as e:
                    self.log.debug(f"SSH key not ready yet (attempt {i+1}): {e}")

                # Non-blocking sleep.
                await asyncio.sleep(2)

            if not public_key:
                self.log.warning(f"Timed out waiting for SSH key generation for {username}")
                return

            # ---------------------------------------------------------------------
            # STEP 2: PUSH KEY TO FORGEJO VIA API
            # ---------------------------------------------------------------------
            
            # Retrieve Admin Credentials.
            admin_user = os.environ.get("INFRA_ADMIN_USERNAME")
            admin_pass_file = os.environ.get("INFRA_ADMIN_PASSWORD_FILE")

            if not admin_user or not admin_pass_file:
                self.log.error("Forgejo admin credentials not found in env. Skipping key sync.")
                return

            # Read password from secret file.
            with open(admin_pass_file, 'r') as f:
                admin_pass = f.read().strip()

            # Forgejo Internal API URL.
            api_url = f"http://forgejo:3000/api/v1/admin/users/{username}/keys"

            payload = {
                "key": public_key,
                "title": "jupyterhub-auto-key",
                "read_only": False
            }

            # Perform the API request in a thread (requests is blocking).
            response = await asyncio.to_thread(
                requests.post,
                api_url,
                json=payload,
                auth=(admin_user, admin_pass),
                timeout=5
            )

            if response.status_code == 201:
                self.log.info(f"Successfully synced SSH key for {username} to Forgejo.")
            elif response.status_code == 422:
                self.log.info(f"SSH key for {username} already exists in Forgejo.")
            else:
                self.log.error(f"Failed to sync SSH key. Status: {response.status_code}, Body: {response.text}")

        except Exception as e:
            # Catch-all to ensure server start doesn't fail if sync fails.
            self.log.error(f"Failed to auto-sync SSH key: {e}")


    async def start(self):
        """
        Override the start method to:
        1. Perform orphaned container pre-check.
        If `self.container_id` is not set (i.e., the Hub thinks this is a new
        server), but a container with `self.container_name` does exist, delete
        it.

        2. Start the container.

        3. Trigger *post-spawn* key sync.
        """

        # ---------------------------------------------------------------------
        # STEP 1: ORPHAN CHECK
        # ---------------------------------------------------------------------

        # Check for the "orphaned" state: no ID in the database.
        if not self.container_id:
            self.log.info(f"No `container_id` in database for {self.user.name}:{self.name}.")

            # Check if a container with this name does exist on the host.
            try:
                container = await self.docker("inspect_container", self.container_name)
                if container:
                    self.log.warning(f"Found orphaned container {container['Id']} for {self.user.name}:{self.name}. Server was likely deleted from the Hub. Removing...")
                    try:
                        await self.docker("remove_container", self.container_name, force=True)
                    except docker.errors.APIError as e:
                        self.log.error(f"Failed to remove orphaned container: {e}")

            except docker.errors.NotFound:
                # This is the normal, "clean start" case.
                self.log.info(f"No container named {self.container_name} found. Proceeding with normal spawn.")

            except Exception as e:
                self.log.error(f"Error during orphaned container check: {e}")

        # ---------------------------------------------------------------------
        # STEP 2: START THE CONTAINER
        # ---------------------------------------------------------------------
        # This returns (ip, port) tuple needed by the Hub.
        ip_port = await super().start()

        # ---------------------------------------------------------------------
        # STEP 3: TRIGGER SSH SYNC
        # ---------------------------------------------------------------------
        # Run this *after* the container is running so we can `exec` into it.
        # Use `create_task` so we don't block the user's login redirect.
        asyncio.create_task(self.sync_ssh_key())

        return ip_port

c.JupyterHub.spawner_class = ResumableDockerSpawner


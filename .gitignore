# ==============================================================================
# Temporary files: Ansible & Logs
# ==============================================================================
*.retry
*.log

# ==============================================================================
# Secrets, Credentials & Example Files
# ==============================================================================
# Keep the `secrets/certs/` directory structure without tracking real secrets
# or certs.
secrets/*
!secrets/.gitkeep
!secrets/certs/
secrets/certs/*
!secrets/certs/.gitkeep
# Explicitly allow only the example file to be tracked by Git.
!secrets/vault.yml.example
# Explicitly ignore the vault password file just in case it is created outside
# the `secrets/` directory.
.vault_pass
# Allow only the example file to be tracked by Git.
ansible/group_vars/all.yml

# ==============================================================================
# Rendered Templates (Generated by Ansible)
# ==============================================================================
config/caddy/Caddyfile
config/caddy/logout-all.html
config/authelia/configuration.yml
config/authelia/users_database.yml
config/forgejo/app.ini
config/grafana/grafana.ini
config/grafana/provisioning/alerting/contact-point.yml
config/jupyterhub/jupyterhub_config.py
config/jupyterhub/image-meta/**/pyproject.toml
compose/docker-compose.yml
images/**/Dockerfile
images/**/pyproject.toml
images/base/motd.sh

# ==============================================================================
# Generated Keys and Certs in build contexts
# ==============================================================================
images/base/forgejo_known_hosts
images/base/internal-ca.pem

# ==============================================================================
# Python & OS Artifacts
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
.DS_Store
Thumbs.db
